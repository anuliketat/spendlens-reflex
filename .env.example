# SpendLens Environment Configuration
# Copy this file to .env and fill in your actual values

# Required: OpenRouter API Key (get from https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Gmail API credentials file path (default: credentials.json in project root)
# GMAIL_CREDENTIALS_FILE=credentials.json
# GMAIL_TOKEN_FILE=token.json

# Optional: Database configuration
# DATABASE_URL=sqlite:///spendlens.db

# Model Configuration
#
# IMPORTANT: The system uses TWO different models for different tasks via OpenRouter API:
#
# 1. DeepSeek V3.2 (deepseek/deepseek-v3.2)
#    - Used for: Analytics, insights, verdict generation, intervention cards
#    - API-based: No local GPU required, faster startup
#    - Set via: ANALYTICS_MODEL (for intel module)
#
# 2. Gemini Flash (google/gemini-3-flash-preview)
#    - Used for: Email extraction, transaction parsing, bank sender filtering
#    - API-based: No local GPU required, faster startup
#    - Hardcoded in email_extraction.py
#
# Optional: Override the default analytics model
ANALYTICS_MODEL=deepseek/deepseek-v3.2
#
# Optional: Use rule-based filtering instead of LLM for bank detection
# USE_LLM_FILTER=true  # Set to 'false' to skip LLM-based bank filtering
