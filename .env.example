# SpendLens Environment Configuration
# Copy this file to .env and fill in your actual values

# Required: Hugging Face Token (get from https://huggingface.co/settings/tokens)
HF_TOKEN=your_huggingface_token_here

# Optional: Gmail API credentials file path (default: credentials.json in project root)
# GMAIL_CREDENTIALS_FILE=credentials.json
# GMAIL_TOKEN_FILE=token.json

# Optional: Database configuration
# DATABASE_URL=sqlite:///spendlens.db

# Optional: Model configuration
# MODEL_NAME=mlabonne/Fin-R1
# QUANTIZATION_BITS=4
